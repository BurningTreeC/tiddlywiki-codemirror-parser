<%if [all[current]tag[critical]] %>
CRITICAL
<%elseif [all[current]tag[warning]] %>
WARNING
<%elseif [all[current]tag[info]] %>
INFO
<%else%>
NORMAL
<%endif%>

!!! Nested Conditionals
<%if [all[current]has[status]] %>
    Status exists:
    <%if [all[current]get[status]match[active]] %>
        Status is active
    <%elseif [all[current]get[status]match[pending]] %>
        Status is pending
    <%else%>
        Status is: {{!!status}}
    <%endif%>
<%endif%>

