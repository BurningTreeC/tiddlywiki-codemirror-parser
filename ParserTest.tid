!! Complete Widget Examples

!!! Todo List Example
<$list filter="[tag[todo]!has[done]sort[priority]]" variable="todo">
    <div class="todo-item">
        <$checkbox tiddler=<<todo>> tag="done">
            <$link to=<<todo>>>
                <$view tiddler=<<todo>> field="title"/>
            </$link>
        </$checkbox>
        <$list filter="[<todo>has[due]]">
            <span class="due-date">Due: <$view tiddler=<<todo>> field="due" format="date"/></span>
        </$list>
    </div>
</$list>

!!! Tab Interface Example
<$vars state="$:/state/mytabs" default="tab1">
    <div class="tc-tab-buttons">
        <$button set=<<state>> setTo="tab1" class={{{ [<state>get[text]match[tab1]then[selected]] }}}>Tab 1</$button>
        <$button set=<<state>> setTo="tab2" class={{{ [<state>get[text]match[tab2]then[selected]] }}}>Tab 2</$button>
        <$button set=<<state>> setTo="tab3" class={{{ [<state>get[text]match[tab3]then[selected]] }}}>Tab 3</$button>
    </div>
    <div class="tc-tab-content">
        <$reveal state=<<state>> type="match" text="tab1" default="tab1" animate="yes">
            Content for tab 1
        </$reveal>
        <$reveal state=<<state>> type="match" text="tab2" animate="yes">
            Content for tab 2
        </$reveal>
        <$reveal state=<<state>> type="match" text="tab3" animate="yes">
            Content for tab 3
        </$reveal>
    </div>
</$vars>

!!! Search Interface Example
<$edit-text tiddler="$:/temp/search" field="text" placeholder="Search..." class="search-input"/>
<$list filter="[all[tiddlers]!is[system]search:title,text{$:/temp/search}sort[title]limit[20]]" emptyMessage="No results found">
    <div class="search-result">
        <$link><$view field="title"/></$link>
        <$list filter="[all[current]has[description]]">
            <div class="result-description"><$view field="description"/></div>
        </$list>
    </div>
</$list>

