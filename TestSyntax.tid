!! Complete Widget Examples

!!! Todo List Example
<$list filter="[tag[todo]!has[done]sort[priority]]" variable="todo">
    <div class="todo-item">
        <$checkbox tiddler=<<todo>> tag="done">
            <$link to=<<todo>>>
                <$view tiddler=<<todo>> field="title"/>
            </$link>
        </$checkbox>
        <$list filter="[<todo>has[due]]">
            <span class="due-date">
                Due: <$view tiddler=<<todo>> field="due" format="date" template="YYYY-MM-DD"/>
            </span>
        </$list>
    </div>
</$list>

!!! Tab Interface Example
<$vars state="$:/state/mytabs" default="tab1">
    <div class="tc-tab-buttons">
        <$button set=<<state>> setTo="tab1" class={{{ [<state>get[text]match[tab1]then[tc-tab-selected]else[]] }}}>
            Tab 1
        </$button>
        <$button set=<<state>> setTo="tab2" class={{{ [<state>get[text]match[tab2]then[tc-tab-selected]else[]] }}}>
            Tab 2
        </$button>
        <$button set=<<state>> setTo="tab3" class={{{ [<state>get[text]match[tab3]then[tc-tab-selected]else[]] }}}>
            Tab 3
        </$button>
    </div>
    <div class="tc-tab-content">
        <$reveal state=<<state>> type="match" text="tab1" default="tab1" animate="yes">
            <div class="tc-tab-panel">
                Content for tab 1 with ''formatting'' and [[links]].
            </div>
        </$reveal>
        <$reveal state=<<state>> type="match" text="tab2" animate="yes">
            <div class="tc-tab-panel">
                Content for tab 2 with <<simpleInlineMacro>>.
            </div>
        </$reveal>
        <$reveal state=<<state>> type="match" text="tab3" animate="yes">
            <div class="tc-tab-panel">
                Content for tab 3 with {{!!title}}.
            </div>
        </$reveal>
    </div>
</$vars>

!!! Search Interface Example
<$edit-text tiddler="$:/temp/search" field="text" placeholder="Search tiddlers..." class="tc-search-input" focusPopup="$:/state/search-popup"/>

