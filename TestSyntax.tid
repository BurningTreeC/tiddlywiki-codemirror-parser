<%if [all[current]has[description]] %>
This tiddler has a description field.
<%endif%>

!!! If-Else
<%if [all[current]tag[important]] %>
This is an important tiddler.
<%else%>
This is a regular tiddler.
<%endif%>

!!! If-Elseif-Else
<%if [all[current]tag[critical]] %>
CRITICAL
<%elseif [all[current]tag[warning]] %>
WARNING
<%elseif [all[current]tag[info]] %>
INFO
<%else%>
NORMAL
<%endif%>

!!! Nested Conditionals
<%if [all[current]has[status]] %>
Status field exists.
<%if [all[current]get[status]match[active]] %>
Status is active.
<%elseif [all[current]get[status]match[pending]] %>
Status is pending.
<%else%>
Status is: {{!!status}}
<%endif%>
<%else%>
No status field.
<%endif%>

!!! Conditional with Complex Filters
<%if [all[current]tags[]count[]compare:number:gt[5]] %>
This tiddler has more than 5 tags.
<%endif%>

<%if [all[current]get[text]length[]compare:number:gt[1000]] %>
This tiddler has more than 1000 characters.
<%endif%>

!!! Conditional with Widgets Inside
<%if [all[current]has[list]] %>
<$list filter="[all[current]get[list]enlist-input[]]" variable="item">
* <<item>>
</$list>
<%endif%>

