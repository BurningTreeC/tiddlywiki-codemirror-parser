</$reveal>

!!! Data Table with Actions
<$vars tableTiddler="$:/temp/table-data">
    <table class="tc-data-table">
        <thead>
            <tr>
                <th>Title</th>
                <th>Tags</th>
                <th>Modified</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <$list filter="[tag[data]sort[title]]" variable="item">
                <tr>
                    <td><$link to=<<item>>><$view tiddler=<<item>> field="title"/></$link></td>
                    <td>
                        <$list filter="[<item>tags[]limit[3]]" variable="tag">
                            <$macrocall $name="tag" tag=<<tag>>/>
                        </$list>
                    </td>
                    <td><$view tiddler=<<item>> field="modified" format="relativedate"/></td>
                    <td>
                        <$button class="tc-btn-invisible" tooltip="Edit">
                            <$action-sendmessage $message="tm-edit-tiddler" $param=<<item>>/>
                            Edit
                        </$button>
                        <$button class="tc-btn-invisible tc-btn-danger" tooltip="Delete">
                            <$action-confirm $message="Delete this tiddler?">
                                <$action-deletetiddler $tiddler=<<item>>/>
                            </$action-confirm>
                            Delete
                        </$button>
                    </td>
                </tr>
            </$list>
        </tbody>
    </table>
</$vars>

!!! Form with Validation
<$let formTiddler="$:/temp/form" errorTiddler="$:/temp/form-errors">
    <div class="tc-form">
        <div class="tc-form-field">
            <label for="name">Name (required):</label>
            <$edit-text tiddler=<<formTiddler>> field="name" placeholder="Enter name" class="tc-input"/>
            <$list filter="[<formTiddler>get[name]is[blank]]">
                <span class="tc-error">Name is required</span>
            </$list>
        </div>

        <div class="tc-form-field">
            <label for="email">Email:</label>
            <$edit-text tiddler=<<formTiddler>> field="email" placeholder="email@example.com" class="tc-input"/>
        </div>

        <div class="tc-form-field">
            <label for="type">Type:</label>
            <$select tiddler=<<formTiddler>> field="type" default="option1">
                <option value="">-- Select --</option>
                <option value="option1">Option 1</option>
                <option value="option2">Option 2</option>
                <option value="option3">Option 3</option>
            </$select>
        </div>

        <div class="tc-form-actions">
            <$button class="tc-btn-primary">
                <$list filter="[<formTiddler>get[name]!is[blank]]" variable="ignore">
                    <$action-createtiddler
                        $basetitle={{{ [<formTiddler>get[name]] }}}
                        email={{{ [<formTiddler>get[email]] }}}
                        type={{{ [<formTiddler>get[type]] }}}
                        tags="submitted"
                    />
                    <$action-setfield $tiddler=<<formTiddler>> name="" email="" type=""/>
                </$list>
                Submit
            </$button>
            <$button class="tc-btn-secondary">
                <$action-setfield $tiddler=<<formTiddler>> name="" email="" type=""/>
                Reset
            </$button>
        </div>
    </div>
</$let>

