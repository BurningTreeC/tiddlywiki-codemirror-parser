! Widgets

!! Self-closing Widgets
<$text text="Hello World"/>
<$view tiddler="MyTiddler" field="title"/>
<$transclude tiddler={{!!source}} mode="block"/>

!! Widgets with Content
<$link to="TargetTiddler">
Click here to navigate
</$link>

<$list filter="[tag[todo]!has[done]]">
<$checkbox field="done"/> <$link/> - <$view field="priority"/>
</$list>

!! Widget Attribute Types
<$button
    set="$:/state/mystate"
    setTo="open"
    class="tc-btn-invisible"
    tooltip="Click to open"
    disabled={{$:/status/loading}}
    actions=<<my-action-macro>>
>
Button Text
</$button>

<$reveal state="$:/state/mystate" type="match" text="open" animate="yes">
This content is revealed when state matches.
</$reveal>

!! Filter Attributes
<$list filter="[all[tiddlers]tag[Journal]sort[created]limit[10]]">
<$link/><br/>
</$list>

!! Indirect Attribute Values
<$text text={{!!title}}/>
<$transclude tiddler={{$:/config/source}}/>

!! Macro Attribute Values
<$set name="myvar" value=<<currentTiddler>>>
Working with <<myvar>>
</$set>

!! Substituted Attribute Values
<$text text=`The title is $(currentTiddler)$`/>
<$button message="tm-notify" param=`Notification for ${[<currentTiddler>get[title]]}$`/>

! HTML Elements

<div class="my-container" style="padding: 1em;">
<span id="unique-id">Inline HTML content</span>
<p>Paragraph with <strong>nested</strong> elements.</p>
</div>

<blockquote cite="https://example.com">
A styled blockquote using HTML.
</blockquote>

<details>
<summary>Click to expand</summary>
Hidden content appears here.
</details>

