title: WikiText Syntax Example
tags: Reference Example

\whitespace trim
\rules except wikilink
\import [[$:/core/macros]]
\parameters (title:"Default Title", count:5)

\define single-line-macro() This is a single-line macro body
\define single-line-with-params(name, value:"default") Param: $name$ = $value$

\define multi-line-macro(name)
This is a multi-line macro definition.
You can use $name$ as a placeholder.

Nested content is supported:

\procedure nested-proc()
This procedure is nested inside the macro definition.
\end nested-proc

Back to the outer macro.
\end

\procedure single-proc(input) Return: $(input)$
\procedure multi-proc(input, format:"html")
Procedures are similar to macros but with different scoping.
Return value: <<return `Processed: $(input)$`>>
\end

\function single-fn(x) [<x>add[1]]
\function multi-fn(tiddler, field:"text")
[<tiddler>get<field>]
\end

\widget $my.single.widget() <span>Single-line widget</span>
\widget $my.multi.widget(content, class:"default-class")
<div class=<<class>>>
<<content>>
</div>
\end

