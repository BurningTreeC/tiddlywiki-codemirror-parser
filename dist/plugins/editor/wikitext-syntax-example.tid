! Conditional Rendering

<%if [<currentTiddler>tag[draft]] %>
This content only appears if the tiddler has the "draft" tag.
<%elseif [<currentTiddler>tag[archived]] %>
This appears for archived tiddlers instead.
<%else%>
This is the default content when no conditions match.
<%endif%>

<%if [<count>compare:number:gt[0]] %>
There are items to display.
<%endif%>

! Variable Substitution

In procedures and functions, use $(variableName)$ syntax:
The current tiddler is $(currentTiddler)$.
The count parameter is $(count)$.

! Entities and Special Characters

HTML entities: &amp; &lt; &gt; &quot; &nbsp; &copy; &mdash;
Numeric entities: &#65; &#x41; &#x1F600;

En-dash: -- and em-dash: ---

Escaped characters: \* \# \! \[ \] \{ \} \< \>

! Filter Expressions (in context)

<$list filter="[all[tiddlers]!is[system]tag[example]sort[title]limit[10]]">
* <$link/> - <$view field="modified" format="relativedate"/>
</$list>

<$count filter="[tag[todo]!has[done]]"/> items remaining

{{{[tag[Project]each[status]get[status]sort[]]}}}

! Keyboard Widget with Priority

<$keyboard key="ctrl+S" message="tm-save" priority="100">
<$keyboard key="escape" message="tm-cancel" priority="50">
<input type="text" placeholder="Press Ctrl+S to save, Escape to cancel"/>
</$keyboard>
</$keyboard>

! Complex Nested Structures

<$list filter="[tag[Category]]" variable="category">
<div class="category-section">
<h2><<category>></h2>
<$list filter="[tag<category>sort[title]]">
<$link>
<$view field="title"/>
</$link>
{{!!description}}
</$list>
</div>
</$list>

! Action Widgets

<$button>
<$action-setfield $tiddler="$:/temp/state" text="active"/>
<$action-sendmessage $message="tm-notify" $param="Action completed"/>
<$action-navigate $to="TargetTiddler"/>
Perform Actions
</$button>

! Let and Set Widgets

<$let
    firstName="John"
    lastName="Doe"
    fullName=`$(firstName)$ $(lastName)$`
    filter={{{ [<firstName>addsuffix[ ]addsuffix<lastName>] }}}
>
Name: <<fullName>>
</$let>

<$set name="dynamicValue" filter="[all[tiddlers]tag[important]count[]]">
There are <<dynamicValue>> important tiddlers.
</$set>

