{
  "name": "@prtw/lang-tiddlywiki",
  "version": "1.0.0",
  "description": "TiddlyWiki5 language support for CodeMirror 6",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./parser": {
      "import": "./dist/parser.js",
      "require": "./dist/parser.cjs",
      "types": "./dist/parser.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "npm run build:parser && npm run build:codemirror",
    "build:parser": "rollup -c rollup.config.parser.js",
    "build:codemirror": "rollup -c rollup.config.codemirror.js",
    "build:all": "rollup -c rollup.config.js",
    "build:tiddlywiki": "rollup -c rollup.config.tiddlywiki.js",
    "build:types": "tsc --emitDeclarationOnly",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build && npm run build:types",
    "test": "echo \"No tests yet\" && exit 0"
  },
  "keywords": [
    "tiddlywiki",
    "tiddlywiki5",
    "codemirror",
    "codemirror6",
    "lezer",
    "parser",
    "syntax-highlighting",
    "editor"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "dependencies": {
    "@lezer/common": "^1.2.1",
    "@lezer/highlight": "^1.2.0"
  },
  "peerDependencies": {
    "@codemirror/autocomplete": "^6.0.0",
    "@codemirror/commands": "^6.0.0",
    "@codemirror/language": "^6.0.0",
    "@codemirror/lang-html": "^6.0.0",
    "@codemirror/state": "^6.0.0",
    "@codemirror/view": "^6.0.0"
  },
  "devDependencies": {
    "@codemirror/autocomplete": "^6.18.0",
    "@codemirror/commands": "^6.6.0",
    "@codemirror/lang-html": "^6.4.0",
    "@codemirror/language": "^6.10.0",
    "@codemirror/state": "^6.4.0",
    "@codemirror/view": "^6.33.0",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/node": "^20.11.0",
    "rollup": "^4.21.0",
    "rollup-plugin-dts": "^6.1.1",
    "tslib": "^2.6.2",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  }
}
