title: $:/plugins/BurningTreeC/tiddlywiki-codemirror/ui/Buttons/spellcheck
tags: $:/tags/EditorToolbar
caption: {{$:/plugins/BurningTreeC/tiddlywiki-codemirror/icons/spellcheck}} Spellcheck
description: Toggle spellcheck
icon: $:/plugins/BurningTreeC/tiddlywiki-codemirror/icons/spellcheck
condition: [<targetTiddler>has[title]]
button-classes: cm6-toolbar-btn-spellcheck

<%if [{$:/config/codemirror-6/spellcheck}match[yes]] %>
<$action-setfield $tiddler="$:/config/codemirror-6/spellcheck" text="no"/>
<%else%>
<$action-setfield $tiddler="$:/config/codemirror-6/spellcheck" text="yes"/>
<%endif%>
