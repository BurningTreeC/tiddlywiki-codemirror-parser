/* ============================================================================
   Vanilla Theme for CodeMirror 6
   ============================================================================
   
   Based on the core TiddlyWiki5 Vanilla palette.
   
   A clean, unobtrusive theme that feels native to TiddlyWiki.
   Uses TW's signature primary blue, code pink, and tag gold.
   
   ============================================================================ */

/* ============================================================================
   Vanilla Color Reference (from $:/palettes/Vanilla)
   ============================================================================
   
   Backgrounds:
   background          #ffffff
   page-background     #f4f4f4
   pre-background      #f5f5f5
   code-background     #f7f7f9
   tiddler-editor-bg   #f8f8f8
   
   Foregrounds:
   foreground          #333333
   muted-foreground    #bbbbbb
   very-muted-fg       #888888
   
   Accent colors:
   primary             #5778d8  (links, buttons)
   tiddler-title-fg    #182955  (dark blue)
   code-foreground     #dd1144  (pink/red)
   tag-background      #eecc66  (gold)
   external-link-fg    #0000ee  (classic blue)
   highlight-bg        #ffff00  (yellow)
   alert-highlight     #881122  (dark red)
   
   ============================================================================ */

/* ============================================================================
   Vanilla Light (Default - matches core TW5)
   ============================================================================ */

.cm6-theme-vanilla,
.cm6-theme-vanilla-light,
[data-cm6-theme="vanilla"],
[data-cm6-theme="vanilla-light"] {
  /* Base palette - from Vanilla */
  --wt-bg: #ffffff;
  --wt-bg-subtle: #f4f4f4;
  --wt-fg: #333333;
  --wt-fg-muted: #999999;
  --wt-fg-faint: #bbbbbb;
  --wt-border: #dddddd;
  --wt-selection: rgba(87, 120, 216, 0.2);
  --wt-line-highlight: rgba(0, 0, 0, 0.03);

  /* Semantic colors - derived from TW5 palette */
  --wt-teal: #2a9d8f;           /* Complementary teal for widgets */
  --wt-teal-dim: #40b4a6;
  --wt-blue: #5778d8;           /* TW primary - links */
  --wt-violet: #6f5cc4;         /* Purple for transclusions */
  --wt-cyan: #2596be;           /* Cyan for filters */
  --wt-orange: #d68a00;         /* Derived from tag gold - macros */
  --wt-rose: #c94c64;           /* Softer than alert - conditionals */
  --wt-amber: #b8860b;          /* Dark goldenrod - attributes */
  --wt-slate: #555555;          /* Code text */
  --wt-purple: #6f5cc4;         /* Pragmas */
  --wt-green: #2e8b57;          /* Sea green - strings */
  --wt-red: #c0392b;            /* Errors */

  /* Formatting */
  --wt-bold: #1a1a1a;
  --wt-italic: #333333;
  --wt-strike: #bbbbbb;
  --wt-underline: #333333;
  --wt-heading: #182955;        /* TW title color */

  /* Code blocks - from TW5 */
  --wt-code-bg: #f7f7f9;
  --wt-code-fg: #dd1144;        /* TW code-foreground */

  /* Highlight */
  --wt-highlight-bg: rgba(255, 255, 0, 0.3);
  --wt-highlight-fg: #333333;

  /* Comments */
  --wt-comment: #999999;
  --wt-mark: #cccccc;
}

/* ============================================================================
   Vanilla Dark (Inverted for dark TW palettes)
   ============================================================================ */

.cm6-theme-vanilla-dark,
[data-cm6-theme="vanilla-dark"] {
  /* Base palette - dark inversion */
  --wt-bg: #1e1e1e;
  --wt-bg-subtle: #2d2d2d;
  --wt-fg: #d4d4d4;
  --wt-fg-muted: #808080;
  --wt-fg-faint: #555555;
  --wt-border: #3d3d3d;
  --wt-selection: rgba(87, 120, 216, 0.35);
  --wt-line-highlight: rgba(255, 255, 255, 0.04);

  /* Semantic colors - brightened for dark bg */
  --wt-teal: #4ec9b0;           /* Brighter teal */
  --wt-teal-dim: #3db39e;
  --wt-blue: #6b8ceb;           /* Brighter primary */
  --wt-violet: #b4a7f5;         /* Brighter purple */
  --wt-cyan: #4fc1e9;           /* Brighter cyan */
  --wt-orange: #e9b563;         /* Brighter orange */
  --wt-rose: #f48fb1;           /* Brighter pink */
  --wt-amber: #ffd54f;          /* Brighter amber */
  --wt-slate: #b0b0b0;          /* Light gray code */
  --wt-purple: #b4a7f5;         /* Pragmas */
  --wt-green: #81c784;          /* Brighter green */
  --wt-red: #ef5350;            /* Brighter red */

  /* Formatting */
  --wt-bold: #ffffff;
  --wt-italic: #d4d4d4;
  --wt-strike: #666666;
  --wt-underline: #d4d4d4;
  --wt-heading: #6b8ceb;        /* Use brightened primary */

  /* Code blocks */
  --wt-code-bg: #2d2d2d;
  --wt-code-fg: #f48fb1;        /* Brightened code pink */

  /* Highlight */
  --wt-highlight-bg: rgba(255, 213, 79, 0.25);
  --wt-highlight-fg: #ffd54f;

  /* Comments */
  --wt-comment: #6a9955;        /* Green-tinted comments */
  --wt-mark: #444444;
}

/* ============================================================================
   Token Overrides - Light
   ============================================================================ */

