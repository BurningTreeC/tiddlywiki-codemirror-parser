!! Complex Nested Example

<$list filter="[tag[Project]]">
<div class="project-card">

!!! {{!!title}}

<$reveal state=<<qualify "$:/state/expand">> type="match" text="yes">
<div class="project-details">

!!!! Description
{{!!description}}

!!!! Tasks
<$list filter="[all[current]tagging[]tag[Task]]">
* <$checkbox tag="Done"/> <$link/>
</$list>

<%if [all[current]tagging[]tag[Task]!tag[Done]count[]match[0]] %>
@@.success All tasks complete!@@
<%else%>
<$count filter="[all[current]tagging[]tag[Task]!tag[Done]]"/> tasks remaining
<%endif%>

</div>
</$reveal>

<$button set=<<qualify "$:/state/expand">> setTo="yes">Expand</$button>
<$button set=<<qualify "$:/state/expand">> setTo="no">Collapse</$button>

</div>
</$list>

