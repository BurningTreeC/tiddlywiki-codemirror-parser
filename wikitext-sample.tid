!! Widgets

!!! Basic Widgets

<$text text="This is a text widget"/>

<$link to="MyTiddler">Click here</$link>

<$button message="tm-notify" param="Success!">
Click Me
</$button>

!!! List Widget

<$list filter="[tag[Examples]limit[5]]">
<div class="item">
<$link/> - <$view field="modified" format="date"/>
</div>
</$list>

!!! Nested Widgets

<$reveal state="$:/state/sample" type="match" text="show">
<div class="revealed-content">
<$list filter="[all[current]tags[]]">
<$link/>
</$list>
</div>
</$reveal>

!!! Let Widget

<$let name="TiddlyWiki" version="5.3.0">
Welcome to <<name>> version <<version>>!
</$let>

!!! Set Widget

<$set name="currentDate" value={{!!created}}>
Created: <<currentDate>>
</$set>

!!! Vars Widget

<$vars greeting="Hello" target="World">
<<greeting>>, <<target>>!
</$vars>

!!! Transclude Widget

<$transclude tiddler="MyTemplate" field="text" mode="block"/>

<$transclude $variable="myMacro" param1="value1"/>

